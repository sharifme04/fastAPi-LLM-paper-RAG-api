APP_NAME=paper-rag-api
APP_VERSION=1.0.0
DEBUG=false

# PostgreSQL with pgvector extension
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/paper_rag

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Embedding + reranker (sentence-transformers HF model IDs)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EMBEDDING_DIM=384

# Retrieval params
TOP_K_VECTOR=10
TOP_K_RERANK=5
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=100

# Cost / rate limits
DAILY_COST_LIMIT=10.00
RATE_LIMIT=20/minute
MAX_PDF_BYTES=52428800

# Eval gate
EVAL_FAITHFULNESS_THRESHOLD=0.7
